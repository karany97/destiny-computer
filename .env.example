# Destiny Computer — operator config
# Copy to `.env` and fill in. `.env` is gitignored.

# ─── Required ──────────────────────────────────────────────────────────────

# Password for browser-side KasmVNC access. The AI uses this too — share it
# with anyone you want to drive the desktop alongside the AI.
DESKTOP_PASSWORD=change-me-to-a-real-passphrase

# Required for the v0.1 driver (uses Anthropic Computer Use). For v0.2+ you
# can set VISION_BACKEND=local-uitars and skip this.
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-key

# ─── Optional ──────────────────────────────────────────────────────────────

# The Destiny Atelier URL the driver should report back to. If unset, the
# driver runs standalone (manual prompts via /api/task).
ATELIER_URL=

# Listen ports on the host
KASMVNC_PORT=6901
DRIVER_PORT=8090

# Desktop screen size (also reported to the AI for click coordinate math)
DESKTOP_RESOLUTION=1280x720

# Hard caps the driver enforces — exceed and it stops + tells the chat
MAX_STEPS_PER_TASK=30
MAX_USD_PER_DAY=1.00

# v0.2+ vision backends: anthropic | local-uitars | local-moondream
VISION_BACKEND=anthropic

# Issue #7 / TRACKING D5 — local-vision (Holo3 via vLLM) compose profile.
# Pre-PR: VISION_BACKEND=local-uitars was a no-op env var. Now the
# `local-vision` profile ships a vLLM sidecar serving Holo3-35B-A3B:
#
#   1. NVIDIA Container Toolkit installed on host (24 GB GPU min)
#   2. VISION_BACKEND=local-uitars above
#   3. docker compose --profile local-vision up -d
#
# When the profile is on, the driver auto-resolves HOLO3_ENDPOINT to
# http://holo3:8000/v1 via compose-network DNS. NOTE: the loop.py
# routing wiring is the v0.3 follow-up (filed as D5b on TRACKING).
# Today operators can curl the sidecar directly while we ship D5b.
# HOLO3_ENDPOINT=http://localhost:8000/v1   # only if you run vLLM yourself
# HOLO3_MODEL=Hcompany/Holo3-35B-A3B        # default; override for variants
# HOLO3_API_KEY=                            # leave empty for default EMPTY

# OPTIONAL Bearer-token auth on every endpoint that touches state or
# spends money. Default unset = no auth (back-compat with the v0.2
# README which assumes operators bind HOST=127.0.0.1 and proxy
# externally). If your driver is reachable from any wider network,
# set this to a long random secret AND have every client send
# `Authorization: Bearer <value>` on every request. /health stays
# open (Docker healthcheck + monitoring). Constant-time comparison
# via hmac.compare_digest defeats timing attacks. Query-param
# tokens are deliberately NOT accepted (anti-leak — would otherwise
# show in access logs, browser history, Referer).
#
# Different env name from atelier-os (ATELIER_API_TOKEN) so operators
# running both fleets on the same host can rotate them independently.
# Generate with: openssl rand -hex 32
# DESTINY_API_TOKEN=

# Issue #5 / TRACKING D3 — per-task rate limit on POST /api/task.
# Format: N/PERIOD where PERIOD ∈ {sec, min, hour}. Invalid spec
# (incl. zero / negative N) falls back to the safe default 10/min.
# Keyed by Bearer token when DESTINY_API_TOKEN is set, else by
# client IP. State lives in driver memory only — restart clears
# all buckets (cumulative spend safety is the MAX_USD_PER_DAY cap).
# Defaults to 10/min — most operators never need to change this.
# DESTINY_TASK_RATE_LIMIT=10/min

# Issue #6 / TRACKING D4 — snapshot/restore API for the desktop container.
# Snapshots are `docker commit destiny-desktop destiny-desktop-snapshot:<id>`
# under the hood. Tag the image repo for snapshots; defaults are sane.
# DESTINY_SNAPSHOT_REPO=destiny-desktop-snapshot
# DESTINY_SNAPSHOT_TIMEOUT_S=60     # docker commit ceiling (image size matters)
# DESTINY_RESTORE_TIMEOUT_S=60      # docker run ceiling (image pull + boot)
